# Dubai RE Monitor — Environment Variables
# Copy this file to .env and fill in your credentials
# NEVER commit .env to git

# ─── Gmail (SMTP) ─────────────────────────────────────────────────────────────
# Use a Gmail App Password — NOT your regular account password
# How to generate: Google Account → Security → 2-Step Verification → App Passwords
SMTP_USER=your.email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
ALERT_EMAIL_TO=your.email@gmail.com   # Where to send alerts (can be same as SMTP_USER)

# ─── WhatsApp via Twilio ──────────────────────────────────────────────────────
# Find these at: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio WhatsApp sandbox number (use this for testing):
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Your WhatsApp number (include country code, e.g. Australia = +61)
TWILIO_WHATSAPP_TO=whatsapp:+61XXXXXXXXX
